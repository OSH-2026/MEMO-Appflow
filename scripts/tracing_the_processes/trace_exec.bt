BEGIN{
	printf("Press Ctrl+C to halt\n");
}
tracepoint:syscalls:sys_enter_execve{
	printf("At time %s, %s executed %s\n",strftime("%Y-%m-%d, %H:%M:%S",nsecs),comm,str(args->filename));
}
tracepoint:syscalls:sys_enter_execveat{
	printf("At time %s, %s executed %s\n",strftime("%Y-%m-%d, %H:%M:%S",nsecs),comm,str(args->filename));
}
END{
	printf("exited\n");
}

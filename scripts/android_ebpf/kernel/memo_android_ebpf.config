# MEMO Android eBPF kernel config fragment.
#
# Apply this to the Android kernel tree used by the target device/emulator.
# The exact merge command depends on that kernel build system:
#   scripts/kconfig/merge_config.sh -m .config scripts/android_ebpf/kernel/memo_android_ebpf.config
# or add these symbols to the device defconfig / GKI fragment.

CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_BPF_JIT=y
CONFIG_BPF_JIT_ALWAYS_ON=y
CONFIG_BPF_EVENTS=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_BPF=y

CONFIG_TRACING=y
CONFIG_FTRACE=y
CONFIG_HAVE_SYSCALL_TRACEPOINTS=y
CONFIG_FTRACE_SYSCALLS=y
CONFIG_TRACEPOINTS=y

CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y
CONFIG_UPROBES=y
CONFIG_UPROBE_EVENTS=y
CONFIG_PERF_EVENTS=y

CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_BTF=y

CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y

# Optional network program/hook support. Useful for future network evidence,
# but not required for the current tracepoint-based MEMO collector.
CONFIG_NET=y
CONFIG_NET_CLS_BPF=y
CONFIG_NET_ACT_BPF=y
CONFIG_NET_CLS_ACT=y
CONFIG_NET_SCH_INGRESS=y

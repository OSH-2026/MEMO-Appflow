function enable_debug_btf_config() {
  ${KERNEL_DIR}/scripts/config --file ${OUT_DIR}/.config \
    -e DEBUG_INFO \
    -e DEBUG_INFO_DWARF4 \
    -e BPF \
    -e BPF_SYSCALL \
    -e BPF_JIT

  (cd ${OUT_DIR} && \
    make O=${OUT_DIR} CLANG_TRIPLE=${CLANG_TRIPLE} CROSS_COMPILE=${CROSS_COMPILE} "${TOOL_ARGS[@]}" ${MAKE_ARGS} olddefconfig)
}

append_cmd POST_DEFCONFIG_CMDS "enable_debug_btf_config"
